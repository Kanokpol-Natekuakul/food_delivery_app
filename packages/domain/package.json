{
  "name": "@app/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pure-TS domain model (state machine, settlement, wallet, dispute, revenue, moderation) — shared by web + api",
  "exports": {
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.5.0"
  }
}
