{
  "name": "@app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API — โฮสต์โดเมน @app/domain บน Fastify + Postgres(Drizzle) + pg-boss(cron) + Lucia(auth)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@app/domain": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "lucia": "^3.2.2",
    "pg-boss": "^10.1.6",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0"
  }
}
